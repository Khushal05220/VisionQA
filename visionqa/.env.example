# VisionQA Environment Variables Template
# Copy this file to .env and fill in your values

# --- Google API ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Google Cloud (for production deployment) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini Model ---
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# --- Firestore ---
FIRESTORE_DATABASE=(default)
TEST_CASES_COLLECTION=test_cases
TEST_RESULTS_COLLECTION=test_results
TEST_PLANS_COLLECTION=test_plans

# --- Cloud Storage ---
GCS_BUCKET=visionqa-screenshots
GCS_SCREENSHOT_PREFIX=screenshots/

# --- Playwright ---
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
SCREENSHOT_DIR=screenshots

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["*"]

# --- Speech ---
SPEECH_LANGUAGE=en-US
